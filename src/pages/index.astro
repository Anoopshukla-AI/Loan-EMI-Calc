---
import Layout from '../layouts/Layout.astro';
import EmiCalculator from '../components/EmiCalculator.astro';
import FaqSection from '../components/FaqSection.astro';

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How accurate is this calculator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It uses the standard reducing-balance EMI formula widely used by major lenders. Your result will closely match most banks, provided the principal, rate, and tenure match exactly."
      }
    },
    {
      "@type": "Question",
      "name": "Should I choose a shorter or longer tenure?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Shorter tenure = higher EMI, much less total interest. Longer tenure = easier monthly payments, but significantly more interest over time. Rule of thumb: keep your EMI under 30% of your take-home pay."
      }
    },
    {
      "@type": "Question",
      "name": "What's the real cost difference between reducing balance and flat rate?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A flat rate of 10% is roughly equivalent to 17–18% reducing balance. If a lender quotes flat rate, compare it to a reducing balance offer — it will almost always be more expensive."
      }
    },
    {
      "@type": "Question",
      "name": "Should I make prepayments on my loan?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Almost always yes for home loans. For personal and car loans, check your lender's prepayment penalty — it's often 2–5% of the outstanding amount."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use this for loans outside India?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Switch to $ (USD) using the currency toggle. The math is identical — only the number format changes. This works for US mortgages, Australian home loans, or any amortizing loan worldwide."
      }
    }
  ]
};

const webAppJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "EMI Calculator Workspace",
  "description": "Calculate monthly payments, compare loan offers side-by-side, check affordability, and model prepayments for home, car, and personal loans.",
  "url": "https://emicalculator.example.com",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<Layout
  title="EMI Calculator — Know Your EMI Before You Sign"
  description="Calculate monthly payments, compare offers side-by-side, and check affordability for home, car, and personal loans. 100% private. Works in ₹ or $."
  ogTitle="EMI Calculator — Know Your EMI Before You Sign"
  ogDescription="Calculate monthly payments, compare offers side-by-side, and check affordability for home, car, and personal loans. 100% private. Works in ₹ or $."
  ogUrl="https://emicalculator.example.com"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(webAppJsonLd)} />
  </Fragment>

  <main class="max-w-5xl mx-auto px-4 py-8 sm:py-12">
    <!-- Hero Section -->
    <div class="mb-10 text-center sm:text-left">
      <h1 class="text-4xl sm:text-5xl md:text-6xl mb-4" style="font-family: var(--font-display); color: var(--color-primary);">
        Know your EMI before you sign the loan.
      </h1>
      <p class="text-lg sm:text-xl text-muted max-w-3xl mb-3">
        Calculate monthly payments, compare offers, and check affordability for home, car, and personal loans — in ₹ or $.
      </p>
      <p class="text-sm font-medium" style="color: var(--color-success);">
        🔒 100% private. No sign-up. Your numbers never leave your browser.
      </p>
    </div>

    <!-- The Calculator Workspace Island -->
    <EmiCalculator />

    <!-- Visual Explainer (Replaces SEO Wall) -->
    <article class="mt-20">
      <h2 class="text-2xl sm:text-3xl mb-6" style="font-family: var(--font-display);">
        How EMI calculation works
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="surface-card p-6">
          <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-primary-light text-primary text-xs">1</span>
            Reducing Balance
          </h3>
          <p class="text-sm text-muted mb-4 font-medium italic">What most banks use</p>
          <ul class="space-y-2 text-sm text-muted list-none pl-0">
            <li class="flex items-start gap-2"><span class="text-primary">•</span> Interest is charged on your remaining balance each month</li>
            <li class="flex items-start gap-2"><span class="text-primary">•</span> As you repay, the interest portion shrinks and principal grows</li>
            <li class="flex items-start gap-2"><span class="text-primary">•</span> Used by: major banks and financial institutions globally</li>
            <li class="flex items-start gap-2"><span class="text-primary">•</span> Formula: <code class="bg-primary-light text-primary px-1.5 py-0.5 rounded ml-1 text-xs">EMI = [P × R × (1+R)<sup>N</sup>] / [(1+R)<sup>N</sup> − 1]</code></li>
          </ul>
        </div>
        
        <div class="surface-card p-6">
          <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-primary-light text-primary text-xs">2</span>
            Flat Rate
          </h3>
          <p class="text-sm text-muted mb-4 font-medium italic">Some car & personal loans</p>
          <ul class="space-y-2 text-sm text-muted list-none pl-0">
            <li class="flex items-start gap-2"><span class="text-amber">•</span> Interest is charged on the original loan amount for the full tenure</li>
            <li class="flex items-start gap-2"><span class="text-amber">•</span> Your interest stays the same every month</li>
            <li class="flex items-start gap-2"><span class="text-amber">•</span> Results in 1.7–1.9× higher effective interest vs. reducing balance</li>
            <li class="flex items-start gap-2"><span class="text-amber">•</span> Used by: some NBFCs and auto financiers</li>
          </ul>
        </div>
      </div>

      <!-- Mini Comparison Table -->
      <div class="surface-card overflow-hidden">
        <div class="px-5 py-4 bg-primary-light border-b border-default">
          <p class="font-medium text-sm m-0">Example: ₹10L loan at 10% for 5 years</p>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-default text-left">
                <th class="px-5 py-3 text-muted font-medium w-1/3">Metric</th>
                <th class="px-5 py-3 text-primary font-semibold w-1/3">Reducing Balance</th>
                <th class="px-5 py-3 font-semibold text-amber w-1/3">Flat Rate</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-default">
                <td class="px-5 py-3 text-muted">Monthly EMI</td>
                <td class="px-5 py-3 font-medium">₹21,247</td>
                <td class="px-5 py-3 font-medium">₹25,000</td>
              </tr>
              <tr class="border-b border-default">
                <td class="px-5 py-3 text-muted">Total Interest</td>
                <td class="px-5 py-3 font-medium">₹2,74,823</td>
                <td class="px-5 py-3 font-medium text-amber">₹5,00,000</td>
              </tr>
              <tr>
                <td class="px-5 py-3 text-muted">Effective Rate</td>
                <td class="px-5 py-3 font-medium">10.00%</td>
                <td class="px-5 py-3 font-medium text-amber">~17.3%</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </article>

    <!-- FAQ Section -->
    <FaqSection />
  </main>
</Layout>

<style>
  html[data-theme="dark"] .bg-primary-light {
    background-color: var(--color-dark-primary-light);
  }
  html[data-theme="dark"] .text-amber {
    color: #fbbf24;
  }
</style>
