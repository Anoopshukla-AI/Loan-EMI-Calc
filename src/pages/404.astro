---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found — EMI Calculator"
  description="The page you're looking for doesn't exist. Return to the EMI Calculator."
>
  <main class="max-w-3xl mx-auto px-4 py-20 text-center">
    <div class="surface-card p-8 sm:p-12 inline-block">
      <p class="text-6xl font-bold text-primary mb-4">404</p>
      <h1 class="text-2xl sm:text-3xl mb-4" style="font-family: var(--font-display);">
        Page Not Found
      </h1>
      <p class="text-base text-muted mb-6 max-w-md mx-auto">
        Sorry, the page you're looking for doesn't exist or has been moved. Let's get you back to calculating your EMI.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-lg text-sm font-medium transition-colors no-underline"
        style="min-height: 44px;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"/>
          <polyline points="12 19 5 12 12 5"/>
        </svg>
        Back to Calculator
      </a>
    </div>
  </main>
</Layout>
