---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us — EMI Calculator"
  description="Have questions or feedback about EMI Calculator? Get in touch with us via email."
>
  <main class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="text-3xl sm:text-4xl mb-6" style="font-family: var(--font-display);">
      Contact Us
    </h1>

    <div class="surface-card p-6 sm:p-8">
      <p class="text-base text-muted mb-6">
        Have a question, found a bug, or want to suggest a feature? We'd love to hear from you. Fill out the form below and we'll get back to you as soon as possible.
      </p>

      <form id="contact-form" class="space-y-5" action="mailto:hello@emicalculator.example.com" method="POST" enctype="text/plain">
        <div>
          <label for="contact-name" class="block text-sm font-medium mb-1.5">Your Name</label>
          <input
            type="text"
            id="contact-name"
            name="name"
            required
            placeholder="John Doe"
            class="w-full px-3 py-2.5 rounded-lg border border-default text-base transition-colors"
            style="min-height: 44px;"
          />
        </div>

        <div>
          <label for="contact-email" class="block text-sm font-medium mb-1.5">Email Address</label>
          <input
            type="email"
            id="contact-email"
            name="email"
            required
            placeholder="you@example.com"
            class="w-full px-3 py-2.5 rounded-lg border border-default text-base transition-colors"
            style="min-height: 44px;"
          />
        </div>

        <div>
          <label for="contact-message" class="block text-sm font-medium mb-1.5">Message</label>
          <textarea
            id="contact-message"
            name="message"
            required
            rows="5"
            placeholder="Type your message here..."
            class="w-full px-3 py-2.5 rounded-lg border border-default text-base transition-colors resize-y"
            style="min-height: 120px;"
          ></textarea>
        </div>

        <button
          type="submit"
          class="bg-primary text-white px-6 py-3 rounded-lg text-sm font-medium transition-colors cursor-pointer"
          style="min-height: 44px;"
        >
          Send Message
        </button>
      </form>

      <p class="text-xs text-muted mt-6">
        Or email us directly at <a href="mailto:hello@emicalculator.example.com" class="text-primary underline">hello@emicalculator.example.com</a>
      </p>
    </div>
  </main>
</Layout>
