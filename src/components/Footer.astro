---
const currentYear = new Date().getFullYear();
const currentMonth = new Date().toLocaleString('en-US', { month: 'long' });
---

<footer class="mt-16 border-t border-default py-10" style="border-color: var(--color-border); background-color: var(--color-bg);">
  <div class="max-w-5xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-10">
      
      <!-- Brand & Trust -->
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 no-underline mb-4" aria-label="Loan Calculator Home">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="28" height="28" aria-hidden="true">
            <circle cx="16" cy="16" r="15" fill="#01696f"/>
            <text x="16" y="21" text-anchor="middle" font-family="system-ui, sans-serif" font-size="13" font-weight="700" fill="white">₹$</text>
          </svg>
          <span class="font-bold text-lg" style="color: var(--color-text);">
            <span class="inr-text">EMI Calc</span>
            <span class="usd-text hidden">Loan Calc</span>
          </span>
        </a>
        <p class="text-sm text-muted mb-6 leading-relaxed">
          A privacy-first loan workspace. Calculate <span class="inr-text">EMI</span><span class="usd-text hidden">monthly payments</span>, check affordability, and model prepayments entirely in your browser. Built independently to keep your financial data private.
        </p>
        <p class="text-xs text-muted font-medium mb-1 flex items-center gap-1.5">
          <span class="inline-block w-2 h-2 rounded-full" style="background-color: var(--color-success);"></span>
          Last updated: {currentMonth} {currentYear}
        </p>
      </div>

      <!-- Links -->
      <div class="md:col-span-1">
        <h4 class="font-semibold text-sm mb-3">Tool</h4>
        <nav aria-label="Footer navigation">
          <ul class="list-none m-0 p-0 space-y-2 text-sm">
            <li><a href="/about" class="text-muted hover:text-primary transition-colors no-underline">About Us</a></li>
            <li><a href="/contact" class="text-muted hover:text-primary transition-colors no-underline">Contact</a></li>
          </ul>
        </nav>
      </div>

      <div class="md:col-span-1">
        <h4 class="font-semibold text-sm mb-3">Legal</h4>
        <nav aria-label="Legal navigation">
          <ul class="list-none m-0 p-0 space-y-2 text-sm">
            <li><a href="/privacy-policy" class="text-muted hover:text-primary transition-colors no-underline">Privacy Policy</a></li>
            <li><a href="/terms-and-conditions" class="text-muted hover:text-primary transition-colors no-underline">Terms of Service</a></li>
          </ul>
        </nav>
      </div>
    </div>

    <!-- Support CTA & Copyright -->
    <div class="pt-6 border-t border-default flex flex-col md:flex-row items-center justify-between gap-6" style="border-color: var(--color-border);">
      <div class="flex-1 order-2 md:order-1 text-center md:text-left">
        <div class="flex items-center gap-4 mb-3 justify-center md:justify-start">
          <a href="/" class="text-sm font-medium hover:text-primary transition-colors">Calculator</a>
          <a href="#faq" class="text-sm font-medium hover:text-primary transition-colors">FAQ</a>
        </div>
        <p class="text-xs text-muted m-0 max-w-2xl mx-auto md:mx-0 leading-relaxed mb-1">
          &copy; {currentYear} <span class="inr-text">EMI Calculator</span><span class="usd-text hidden">Loan Calculator</span>. All rights reserved. Built independently. Support helps keep this tool free and improve features.
        </p>
        <p class="text-xs text-muted m-0 max-w-2xl mx-auto md:mx-0 leading-relaxed">
          <strong>Disclaimer:</strong> Calculations are for illustrative purposes and assume a fixed interest rate. Actual loan terms may vary based on lender-specific <span class="inr-text">GST, processing fees</span><span class="usd-text hidden">taxes, origination fees</span>, and credit adjustments. Always verify the final figures with your lender.
        </p>
      </div>
      
      <div class="order-1 md:order-2 shrink-0">
        <a href="https://buymeachai.ezee.li/anoops" target="_blank" rel="noopener noreferrer" class="inline-block transition-transform hover:scale-105 active:scale-95" aria-label="Support with Buy Me A Chai">
          <img src="https://buymeachai.ezee.li/assets/images/buymeachai-button.png" alt="Buy Me A Chai" width="160" class="rounded-md opacity-90 hover:opacity-100 transition-opacity">
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  html[data-theme="dark"] footer {
    background-color: var(--color-dark-bg) !important;
    border-color: var(--color-dark-border) !important;
  }
  html[data-theme="dark"] footer a {
    color: var(--color-dark-text-muted) !important;
  }
  html[data-theme="dark"] footer a:hover {
    color: var(--color-dark-primary) !important;
  }
</style>
