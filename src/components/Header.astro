---
const navLinks = [
  { href: '/', label: 'Calculator' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 border-b border-default" style="background-color: var(--color-bg);">
  <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 no-underline" aria-label="EMI Calculator Home">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" width="32" height="32" aria-hidden="true">
        <circle cx="16" cy="16" r="15" fill="#01696f"/>
        <text x="16" y="21" text-anchor="middle" font-family="system-ui, sans-serif" font-size="13" font-weight="700" fill="white">₹$</text>
      </svg>
      <span class="font-bold text-lg" style="color: var(--color-text);">EMI Calc</span>
    </a>

    <!-- Nav + Dark Mode Toggle -->
    <div class="flex items-center gap-1 sm:gap-4">
      <nav aria-label="Main navigation">
        <ul class="flex items-center gap-1 sm:gap-3 list-none m-0 p-0">
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="px-2 py-2 text-sm rounded-md transition-colors hover:bg-primary-light"
                style="color: var(--color-text-muted); text-decoration: none;"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Dark Mode Toggle -->
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        class="p-2 rounded-md transition-colors hover:bg-primary-light"
        style="min-width: 44px; min-height: 44px; display: flex; align-items: center; justify-content: center;"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<style>
  html[data-theme="dark"] header {
    background-color: var(--color-dark-bg) !important;
    border-color: var(--color-dark-border) !important;
  }
  html[data-theme="dark"] header a,
  html[data-theme="dark"] header span {
    color: var(--color-dark-text) !important;
  }
  html[data-theme="dark"] header a:hover {
    background-color: var(--color-dark-primary-light) !important;
  }
  html[data-theme="dark"] #theme-toggle:hover {
    background-color: var(--color-dark-primary-light) !important;
  }
</style>
