---
/**
 * FaqSection — Accordion FAQ with accessible keyboard navigation
 */

interface FaqItem {
  question: string;
  answer: string;
}

const faqs: FaqItem[] = [
  {
    question: "How accurate is this loan calculator?",
    answer: "<strong>Very accurate for fixed-rate loans.</strong> It uses the standard reducing-balance amortization formula used by major lenders globally. Results match most bank statements precisely when the principal, rate, and <span class='inr-text'>tenure</span><span class='usd-text hidden'>loan term</span> are correct. <em>Calculations do not account for floating-rate changes, lender-specific fees, or insurance charges.</em>"
  },
  {
    question: "What is an amortization schedule?",
    answer: "<strong>An amortization schedule</strong> is a complete table of every loan payment, showing how much goes to principal and how much goes to interest each month. Early payments are mostly interest; later payments are mostly principal. It helps you see your exact payoff date and total cost."
  },
  {
    question: "Should I choose a shorter or longer <span class='inr-text'>loan tenure</span><span class='usd-text hidden'>loan term</span>?",
    answer: "<strong>Shorter <span class='inr-text'>tenure</span><span class='usd-text hidden'>term</span>:</strong> Higher <span class='inr-text'>EMI</span><span class='usd-text hidden'>monthly payment</span>, but much less total interest. <strong>Longer <span class='inr-text'>tenure</span><span class='usd-text hidden'>term</span>:</strong> Lower payments, but significantly more interest paid overall. A common guideline is to keep your <span class='inr-text'>EMI</span><span class='usd-text hidden'>monthly payment</span> below 30% of your take-home income."
  },
  {
    question: "What is the difference between reducing balance and flat rate?",
    answer: "<strong>Reducing balance:</strong> Interest is calculated on the remaining principal each month — the standard used by most banks globally. <strong>Flat rate:</strong> Interest is calculated on the original loan amount for the full <span class='inr-text'>tenure</span><span class='usd-text hidden'>term</span>. A flat rate of 10% is equivalent to roughly 17–18% reducing balance — significantly more expensive. <span class='inr-text'>Flat rates are common with some NBFCs and two-wheeler financiers.</span><span class='usd-text hidden'>Flat rates sometimes appear in personal and vehicle loans from non-bank lenders.</span>"
  },
  {
    question: "Should I make prepayments?",
    answer: "<strong>Generally yes</strong> — each extra payment directly reduces your principal, cutting total interest. <span class='inr-text'>For home loans, most banks allow penalty-free prepayments as per RBI guidelines. For personal and car loans, check for prepayment charges (typically 2–5% of the outstanding balance).</span><span class='usd-text hidden'>For mortgages, confirm there is no prepayment penalty first. For auto and personal loans, check your lender's terms — a penalty can offset the interest savings.</span>"
  }
];
---

<section id="faq" class="mt-16 border-t border-default pt-12" style="border-color: var(--color-border);">
  <h2 class="text-2xl sm:text-3xl mb-2" style="font-family: var(--font-display);">
    Frequently Asked Questions
  </h2>
  <p class="text-sm text-muted mb-6">Quick answers to common borrowing questions.</p>

  <div class="space-y-3">
    {faqs.map((faq, index) => (
      <div class="surface-card overflow-hidden">
        <button
          type="button"
          class="faq-toggle w-full flex items-center justify-between gap-3 px-4 py-4 text-left text-base font-medium cursor-pointer transition-colors hover:bg-primary-light"
          style="min-height: 44px; background: none; border: none; color: var(--color-text);"
          aria-expanded="false"
          aria-controls={`faq-answer-${index}`}
        >
          <span set:html={faq.question}></span>
          <svg class="faq-icon shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transition: transform 0.2s;">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>
        <div
          id={`faq-answer-${index}`}
          class="faq-answer px-4"
          role="region"
        >
          <p class="text-sm leading-relaxed text-muted pb-4 m-0" set:html={faq.answer}></p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  html[data-theme="dark"] .faq-toggle {
    color: var(--color-dark-text) !important;
  }
  html[data-theme="dark"] .faq-toggle:hover {
    background-color: var(--color-dark-primary-light) !important;
  }
</style>

<script>
  // FAQ Accordion logic
  document.querySelectorAll('.faq-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answerId = btn.getAttribute('aria-controls')!;
      const answer = document.getElementById(answerId)!;
      const icon = btn.querySelector('.faq-icon') as SVGElement;

      // Close all others
      document.querySelectorAll('.faq-toggle').forEach(otherBtn => {
        if (otherBtn !== btn) {
          otherBtn.setAttribute('aria-expanded', 'false');
          const otherId = otherBtn.getAttribute('aria-controls')!;
          const otherAnswer = document.getElementById(otherId)!;
          otherAnswer.classList.remove('open');
          const otherIcon = otherBtn.querySelector('.faq-icon') as SVGElement;
          if (otherIcon) otherIcon.style.transform = 'rotate(0)';
        }
      });

      // Toggle current
      btn.setAttribute('aria-expanded', String(!expanded));
      answer.classList.toggle('open');
      if (icon) icon.style.transform = expanded ? 'rotate(0)' : 'rotate(180deg)';
    });
  });
</script>
