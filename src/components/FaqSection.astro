---
/**
 * FaqSection — Accordion FAQ with accessible keyboard navigation
 */

interface FaqItem {
  question: string;
  answer: string;
}

const faqs: FaqItem[] = [
  {
    question: "How accurate is this loan calculator?",
    answer: "It uses the standard reducing-balance <span class='inr-text'>EMI</span><span class='usd-text hidden'>amortization</span> formula widely used by major lenders worldwide. Your result will closely match most banks, provided the principal, interest rate, and <span class='inr-text'>tenure</span><span class='usd-text hidden'>loan term</span> match exactly. <br><br><em>Note: Calculations are illustrative and do not account for floating-rate adjustments or <span class='inr-text'>GST/processing fees</span><span class='usd-text hidden'>taxes/origination fees</span>.</em>"
  },
  {
    question: "What is an amortization schedule?",
    answer: "<strong>An amortization schedule</strong> is a complete table of periodic loan payments, showing the amount of principal and the amount of interest that comprise each payment until the loan is paid off at the end of its term."
  },
  {
    question: "Should I choose a shorter or longer <span class='inr-text'>tenure</span><span class='usd-text hidden'>loan term</span>?",
    answer: "A shorter <span class='inr-text'>tenure</span><span class='usd-text hidden'>term</span> results in a higher <span class='inr-text'>EMI</span><span class='usd-text hidden'>monthly payment</span>, but much less total interest paid over the life of the loan. A longer <span class='inr-text'>tenure</span><span class='usd-text hidden'>term</span> provides easier monthly payments, but significantly more total interest. A common rule of thumb is to keep your <span class='inr-text'>EMI</span><span class='usd-text hidden'>monthly payment</span> under 30% of your take-home pay."
  },
  {
    question: "What is the difference between reducing balance and flat rate loans?",
    answer: "In a <strong>reducing balance loan</strong>, interest is charged only on the remaining principal each month. In a <strong>flat rate loan</strong>, interest is charged on the original loan amount for the full term. A flat rate of 10% is roughly equivalent to a 17–18% reducing balance rate, making flat rate loans significantly more expensive."
  },
  {
    question: "Should I make prepayments on my loan?",
    answer: "<span class='inr-text'>Almost always yes for home loans (most banks allow penalty-free prepayments after 1 year under RBI rules). For personal and car loans, check your lender's prepayment penalty — it's often 2–5% of the outstanding amount.</span><span class='usd-text hidden'>Almost always yes for mortgages and home loans, provided there are no prepayment penalties. For personal and auto loans, check if your lender charges a prepayment penalty.</span> Making extra payments reduces your principal faster, saving you significant interest."
  }
];
---

<section id="faq" class="mt-16 border-t border-default pt-12" style="border-color: var(--color-border);">
  <h2 class="text-2xl sm:text-3xl mb-2" style="font-family: var(--font-display);">
    Frequently Asked Questions
  </h2>
  <p class="text-sm text-muted mb-6">Quick answers to common borrowing questions.</p>

  <div class="space-y-3">
    {faqs.map((faq, index) => (
      <div class="surface-card overflow-hidden">
        <button
          type="button"
          class="faq-toggle w-full flex items-center justify-between gap-3 px-4 py-4 text-left text-base font-medium cursor-pointer transition-colors hover:bg-primary-light"
          style="min-height: 44px; background: none; border: none; color: var(--color-text);"
          aria-expanded="false"
          aria-controls={`faq-answer-${index}`}
        >
          <span set:html={faq.question}></span>
          <svg class="faq-icon shrink-0" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transition: transform 0.2s;">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>
        <div
          id={`faq-answer-${index}`}
          class="faq-answer px-4"
          role="region"
        >
          <p class="text-sm leading-relaxed text-muted pb-4 m-0" set:html={faq.answer}></p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  html[data-theme="dark"] .faq-toggle {
    color: var(--color-dark-text) !important;
  }
  html[data-theme="dark"] .faq-toggle:hover {
    background-color: var(--color-dark-primary-light) !important;
  }
</style>

<script>
  // FAQ Accordion logic
  document.querySelectorAll('.faq-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answerId = btn.getAttribute('aria-controls')!;
      const answer = document.getElementById(answerId)!;
      const icon = btn.querySelector('.faq-icon') as SVGElement;

      // Close all others
      document.querySelectorAll('.faq-toggle').forEach(otherBtn => {
        if (otherBtn !== btn) {
          otherBtn.setAttribute('aria-expanded', 'false');
          const otherId = otherBtn.getAttribute('aria-controls')!;
          const otherAnswer = document.getElementById(otherId)!;
          otherAnswer.classList.remove('open');
          const otherIcon = otherBtn.querySelector('.faq-icon') as SVGElement;
          if (otherIcon) otherIcon.style.transform = 'rotate(0)';
        }
      });

      // Toggle current
      btn.setAttribute('aria-expanded', String(!expanded));
      answer.classList.toggle('open');
      if (icon) icon.style.transform = expanded ? 'rotate(0)' : 'rotate(180deg)';
    });
  });
</script>
